# ThreatLens backend configuration — copy to backend/.env and fill in.
# backend/.env is git-ignored; never commit real secrets.

# abuse.ch Auth-Key (free: register at https://auth.abuse.ch and copy the
# Auth-Key from your profile). One key works across all abuse.ch providers
# (MalwareBazaar, URLhaus). Set the shared key below and you're done.
ABUSE_CH_AUTH_KEY=

# Optional per-provider overrides (default to ABUSE_CH_AUTH_KEY above):
# MALWAREBAZAAR_AUTH_KEY=
# URLHAUS_AUTH_KEY=

# AbuseIPDB API key (separate service from abuse.ch). Free key at
# https://www.abuseipdb.com — Account → API. Used for IPv4/IPv6 reputation.
ABUSEIPDB_API_KEY=

# Optional: comma-separated CORS origins for a separately-hosted frontend.
# THREATLENS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
