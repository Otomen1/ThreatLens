# ThreatLens backend configuration — copy to backend/.env and fill in.
# backend/.env is git-ignored; never commit real secrets.

# abuse.ch Auth-Key (free: register at https://auth.abuse.ch and copy the
# Auth-Key from your profile). One key works across all abuse.ch providers
# (MalwareBazaar, URLhaus). Set the shared key below and you're done.
ABUSE_CH_AUTH_KEY=

# Optional per-provider overrides (default to ABUSE_CH_AUTH_KEY above):
# MALWAREBAZAAR_AUTH_KEY=
# URLHAUS_AUTH_KEY=

# AbuseIPDB API key (separate service from abuse.ch). Free key at
# https://www.abuseipdb.com — Account → API. Used for IPv4/IPv6 reputation.
ABUSEIPDB_API_KEY=

# AlienVault OTX API key (optional — OTX also works anonymously). Free key at
# https://otx.alienvault.com — Settings → API Integration. Threat-context pulses
# for IPs, domains, URLs, and file hashes.
OTX_API_KEY=

# Optional: comma-separated CORS origins for a separately-hosted frontend.
# THREATLENS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: override where saved investigations (Investigation Workspace) are
# stored on local disk. Default: data/workspace, created on first use.
# Required on read-only-filesystem deployments (e.g. Vercel, where only /tmp
# is writable) — frontend/vercel.json already sets this for the deployed
# function. Note: paths under /tmp are ephemeral there, not durable storage.
# THREATLENS_WORKSPACE_DIR=data/workspace

#####################################
# AI Configuration
#####################################

# Enable or disable the AI explanation layer.
# AI never changes deterministic findings,
# confidence, severity, priority, or recommendations.
# It only explains InvestigationSummary.
AI_ENABLED=false

# Current supported provider.
AI_PROVIDER=ollama

# Ollama endpoint.
OLLAMA_URL=http://localhost:11434

# Default lightweight development model.
# (The engine's built-in default when unset is qwen3:8b; qwen3:4b is a lighter
#  choice that runs on an 8GB laptop — see the README "AI Setup" section.)
OLLAMA_MODEL=qwen3:4b

# AI request timeout (seconds).
AI_TIMEOUT=60
